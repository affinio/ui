{
  "extends": "../../tsconfig.core.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "baseUrl": ".",
    "paths": {
      "@affino/combobox-core": ["../combobox-core/src/index.ts"],
      "@affino/combobox-core/*": ["../combobox-core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__"],
  "references": [
    { "path": "../combobox-core" }
  ]
}